# ══════════════════════════════════════════════
# PENHIRE ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# SERVER
PORT=3000
NODE_ENV=production
BASE_URL=https://penhire.com

# JWT SECRET (change this to a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_immediately_2024

# DATABASE
DB_PATH=./database/penhire.db

# ── M-PESA (Safaricom Daraja API) ──
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://penhire.com/api/mpesa/callback
MPESA_ENV=production
# For testing use: https://sandbox.safaricom.co.ke
# For production use: https://api.safaricom.co.ke
MPESA_BASE_URL=https://api.safaricom.co.ke

# ── PAYPAL ──
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live
# sandbox or live

# ── EMAIL (Gmail SMTP) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=PenHire <noreply@penhire.com>

# ── ADMIN ──
ADMIN_EMAIL=admin@penhire.com
ADMIN_PASSWORD=change_this_strong_password

# ── SCRAPING ──
# How often to scrape (cron format)
# "0 */2 * * *" = every 2 hours
SCRAPE_INTERVAL=0 */2 * * *
MAX_JOBS_PER_SCRAPE=50

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

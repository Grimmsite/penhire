# ── App ──────────────────────────────────────────
PORT=3000
BASE_URL=https://your-app.onrender.com   # Change this to your Render URL
JWT_SECRET=your_super_secret_jwt_key_here

# ── IntaSend ─────────────────────────────────────
# Get these from: IntaSend Dashboard → Integrations → API Keys
INTASEND_PUBLISHABLE_KEY=ISPubKey_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTASEND_SECRET_KEY=ISSecretKey_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTASEND_TEST_MODE=false   # Set to true for testing, false for live

# ── Email ─────────────────────────────────────────
# (Keep your existing email settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Admin ─────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_admin_password
